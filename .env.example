# Disney Reservation Monitor — Environment Variables
# Copy this file to .env and fill in the values you want to use.

# ---------------------------------------------------------------------------
# MyDisney account credentials (REQUIRED)
# Disney's booking site requires login to check availability.
# ---------------------------------------------------------------------------

# Your Walt Disney World / MyDisney account email
DISNEYRES_EMAIL=you@example.com

# Your MyDisney account password
DISNEYRES_PASSWORD=your_disney_password_here

# ---------------------------------------------------------------------------
# The rest are optional
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Email notifications
# When these are all set, an email is sent when a reservation is found.
# ---------------------------------------------------------------------------

# SMTP server hostname (default: smtp.gmail.com)
# DISNEYRES_SMTP_HOST=smtp.gmail.com

# SMTP port (default: 587 for STARTTLS)
# DISNEYRES_SMTP_PORT=587

# Your sending email address (e.g. a Gmail account)
# DISNEYRES_SMTP_USER=you@gmail.com

# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# NOT your regular Gmail password. Requires 2-Step Verification to be enabled.
# DISNEYRES_SMTP_PASS=your_app_password_here

# Recipient address(es) — where the alert should be sent.
# Separate multiple addresses with commas:
# DISNEYRES_EMAIL_TO=you@example.com, partner@example.com

# ---------------------------------------------------------------------------
# Polling
# ---------------------------------------------------------------------------

# Override the default 5-minute check interval (value in seconds)
# CHECK_INTERVAL_SECONDS=300

# ---------------------------------------------------------------------------
# Advanced: custom availability endpoint
# Only change this if Disney has updated their API and the default no longer works.
# See wdw_api.py for instructions on finding the current endpoint.
# ---------------------------------------------------------------------------

# DISNEYRES_AVAILABILITY_URL=https://disneyworld.disney.go.com/finder/api/v1/dining/nextAvailabilitySearch/
